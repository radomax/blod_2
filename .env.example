# Railway Environment Variables Template
# Copy this to .env for local development
# Railway will automatically set these for production

# Database Configuration (automatically set by Railway MySQL)
MYSQL_URL=mysql://user:password@host:port/database
MYSQLHOST=your-mysql-host.railway.internal
MYSQLPORT=3306
MYSQLDATABASE=railway
MYSQLUSER=root
MYSQLPASSWORD=your-password

# Alternative Database Variables (optional)
DB_HOST=${MYSQLHOST}
DB_PORT=${MYSQLPORT}
DB_NAME=${MYSQLDATABASE}
DB_USER=${MYSQLUSER}
DB_PASS=${MYSQLPASSWORD}

# Application Settings
APP_NAME=Blood Pressure Monitoring System
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-app.railway.app

# Timezone
TIMEZONE=Europe/Oslo

# Session Configuration
SESSION_LIFETIME=1800

# Security
ENCRYPTION_KEY=generate-a-random-32-character-string

# Admin Credentials (change these!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# API Settings
API_RATE_LIMIT=100
API_RATE_WINDOW=3600

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_API=true
ENABLE_EXPORT=true

# Email Configuration (if needed)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Logging
LOG_LEVEL=error
LOG_CHANNEL=daily

# Railway Specific
PORT=80
RAILWAY_ENVIRONMENT=production